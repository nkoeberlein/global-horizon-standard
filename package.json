{
  "name": "global-horizon-standard-repo",
  "private": true,
  "engines": {
    "node": ">=25.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:core": "npm run build --workspace=packages/core",
    "build:cli": "npm run build --workspace=packages/cli",
    "build:api": "npm run build --workspace=packages/api",
    "dev:api": "npm run build:core && npm run dev --workspace=packages/api",
    "dev:web": "npm run build:core && npm run dev --workspace=packages/web",
    "build": "npm run build:core && npm run build:cli && npm run build:api && npm run build --workspace=packages/web",
    "test": "vitest run",
    "lint": "biome ci .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "typescript": "^6.0.2",
    "vite-plugin-web-extension": "^4.5.1",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "shell-quote": "^1.8.4",
    "tmp": "^0.2.6",
    "uuid": "^11.1.1",
    "vite": "^8.1.4",
    "esbuild": "^0.28.1"
  }
}
