# ==========================================
# GHS - Global Horizon Standard .gitignore
# ==========================================

# Dependencies
node_modules/

# Build output
dist/
build/
out/
*.tsbuildinfo

# Vite cache
.vite/

# Environment variables
.env
.env.local
.env.*.local

# OS artifacts
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Data
archive/*
assets/*
