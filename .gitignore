# ==========================================
# GHS - Global Horizon Standard .gitignore
# ==========================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.*

# --- Build & Output ---
dist/
build/
out/
bin/
# TypeScript build info
*.tsbuildinfo
# Vite specific
.vite/
# Vercel / Netlify deployments
.vercel
.netlify

# --- Testing & Coverage ---
coverage/
*.lcov
.nyc_output
junit.xml
# Vitest UI / caches
.vitest/
# Playwright (MCP-Snapshots & Reports)
.playwright-mcp/
playwright-report/
test-results/

# --- Environment & Secrets ---
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# --- Debug & Logs ---
logs/
*.log
nohup.out
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS Artifacts ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Editor / IDE ---
# Wir ignorieren lokale Editor-Settings, 
# außer du willst Shared-Settings im Team nutzen.
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.iml
.claude/settings.local.json
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# --- Data & Assets ---
archive/
temp/
tmp/
