{
  "name": "ghs-time",
  "version": "1.0.0",
  "description": "The official Global Horizon Standard (GHS) time converter — 13-month calendar, @Beats decimal time, Human Era.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nkoeberlein/global-horizon-standard.git"
  },
  "homepage": "https://github.com/nkoeberlein/global-horizon-standard",
  "bugs": {
    "url": "https://github.com/nkoeberlein/global-horizon-standard/issues"
  },
  "keywords": [
    "ghs",
    "time",
    "calendar",
    "decimal-time",
    "beats",
    "human-era",
    "13-months",
    "aurora-week"
  ],
  "author": "Nikolaus Köberlein",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsdown": "^0.21.7",
    "typescript": "^6.0.0"
  }
}
