{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["ES2019"],
    "rootDir": "./src",
    "declaration": true,
    "strict": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}
